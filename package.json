{
  "name": "guis-arc-enterprise-v7",
  "version": "7.0.0",
  "type": "module",
  "scripts": {
    "worker:dev": "wrangler dev backend/src/index.js --local",
    "d1:init": "wrangler d1 execute guis_arc_enterprise --local --file=database/d1/schema.sql",
    "d1:seed": "wrangler d1 execute guis_arc_enterprise --local --file=database/d1/seed.sql",
    "deploy:pages": "wrangler pages deploy frontend --project-name=guis-arc-enterprise",
    "deploy:worker": "wrangler deploy backend/src/index.js --name guis-arc-api"
  },
  "devDependencies": {
    "wrangler": "latest"
  }
}