{
  "name": "guis-arc-os-v7",
  "version": "8.6.0",
  "type": "module",
  "scripts": {
    "worker:dev": "wrangler dev backend/src/index.js --local",
    "d1:init": "wrangler d1 execute guis_arc_os --local --file=database/d1/schema.sql",
    "d1:seed": "wrangler d1 execute guis_arc_os --local --file=database/d1/seed.sql",
    "deploy:pages": "wrangler pages deploy frontend --project-name=guis-arc-os-enterprise",
    "deploy:worker": "wrangler deploy --config wrangler.worker.toml",
    "deploy:all": "npm run deploy:worker && npm run deploy:pages",
    "doctor": "wrangler whoami && wrangler pages project list"
  },
  "devDependencies": {
    "wrangler": "latest"
  }
}